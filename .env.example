# ===== LLM 配置（二选一） =====

# 方案 A：不配置 → 纯检索模式（零依赖，直接使用）
# 搜索到的书摘会直接展示，你可以复制内容到 CodeBuddy 进一步分析
# 无需任何配置，删掉或留空 API Key 即可
LLM_API_KEY=
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b

# 方案 B：Ollama 本地模型（推荐，免费离线）
# 1. 安装 Ollama: https://ollama.com
# 2. 下载模型: ollama pull qwen2.5:7b
# 3. 取消下面注释即可
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b

# 方案 C：任意 OpenAI 兼容 API
# LLM_API_KEY=sk-your-real-key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ===== 其他配置 =====
CHROMA_PERSIST_DIR=./data/chroma
COLLECTION_NAME=books_rag
EMBED_MODEL_NAME=BAAI/bge-small-zh-v1.5
HOST=0.0.0.0
PORT=8000
